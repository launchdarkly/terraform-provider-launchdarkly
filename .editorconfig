# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs (gofmt enforces this).
[*.go]
indent_style = tab
indent_size = 4

# Makefiles require tabs.
[{Makefile,GNUmakefile}]
indent_style = tab
indent_size = 4

# Markdown: don't trim trailing whitespace (two trailing spaces = hard line break).
[*.md]
trim_trailing_whitespace = false

# Generated files — leave alone.
[launchdarkly/integration_configs_generated.go]
indent_style = tab
indent_size = 4
trim_trailing_whitespace = false
